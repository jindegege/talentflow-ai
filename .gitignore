# ==========================================
# Python / 通用
# ==========================================
# 字节码文件
__pycache__/
*.py[cod]
*$py.class
*.so

# 虚拟环境 (venv, venv3, virtualenv)
venv/
env/
ENV/
.venv/

# IDE 设置 (PyCharm, VS Code)
.idea/
.vscode/
*.swp
*.swo
*~

# Jupyter Notebook
.ipynb_checkpoints

# ==========================================
# 环境变量与配置 (非常重要)
# ==========================================
# 包含数据库密码、密钥等敏感信息的文件
.env
.env.local
.env.*.local

# 配置文件（如果包含敏感信息）
# config.py
# settings.py

# ==========================================
# 数据库 (SQLite)
# ==========================================
# 如果你使用 SQLite 作为开发数据库
*.db
*.sqlite
*.sqlite3

# ==========================================
# 项目特定文件 (Smart Customer)
# ==========================================
# 上传的文件目录 (如果你的项目允许用户上传文件)
uploads/
static/uploads/
media/

# 日志文件
*.log
logs/

# 测试与覆盖率报告
.pytest_cache/
.coverage
htmlcov/
.tox/

# 打包与分发
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
*.egg

# mypy (类型检查)
.mypy_cache/